#include "lora.h"

/* ==== INTERNAL MACROS ==== */
#define NSS_LOW()  HAL_GPIO_WritePin(LORA_NSS_PORT, LORA_NSS_PIN, GPIO_PIN_RESET)
#define NSS_HIGH() HAL_GPIO_WritePin(LORA_NSS_PORT, LORA_NSS_PIN, GPIO_PIN_SET)

/* ==== LOW LEVEL SPI ==== */
static uint8_t LoRa_SPI(uint8_t data)
{
    uint8_t rx;
    HAL_SPI_TransmitReceive(&LORA_SPI_HANDLE, &data, &rx, 1, 100);
    return rx;
}

static void LoRa_WriteReg(uint8_t addr, uint8_t data)
{
    NSS_LOW();
    LoRa_SPI(addr | 0x80);
    LoRa_SPI(data);
    NSS_HIGH();
}

static uint8_t LoRa_ReadReg(uint8_t addr)
{
    uint8_t val;
    NSS_LOW();
    LoRa_SPI(addr & 0x7F);
    val = LoRa_SPI(0x00);
    NSS_HIGH();
    return val;
}

/* ==== RESET ==== */
static void LoRa_Reset(void)
{
    HAL_GPIO_WritePin(LORA_RESET_PORT, LORA_RESET_PIN, GPIO_PIN_RESET);
    HAL_Delay(10);
    HAL_GPIO_WritePin(LORA_RESET_PORT, LORA_RESET_PIN, GPIO_PIN_SET);
    HAL_Delay(10);
}

/* ==== INIT ==== */
void LoRa_Init(void)
{
    LoRa_Reset();

    // Sleep
    LoRa_WriteReg(0x01, 0x80);
    HAL_Delay(10);

    // Standby
    LoRa_WriteReg(0x01, 0x81);

    // Frequency = 433 MHz
    LoRa_WriteReg(0x06, 0x6C);
    LoRa_WriteReg(0x07, 0x80);
    LoRa_WriteReg(0x08, 0x00);

    // Modem config (BW, CR, SF)
    LoRa_WriteReg(0x1D, 0x72);
    LoRa_WriteReg(0x1E, 0x74);
    LoRa_WriteReg(0x26, 0x04);

    // TX Power
    LoRa_WriteReg(0x09, 0x8F);

    // LNA boost
    LoRa_WriteReg(0x0C, 0x23);

    // FIFO base
    LoRa_WriteReg(0x0E, 0x00);
    LoRa_WriteReg(0x0F, 0x00);

    // Sync word
    LoRa_WriteReg(0x39, 0x34);

    // Clear IRQ
    LoRa_WriteReg(0x12, 0xFF);
}

/* ==== MODE CONTROL ==== */
void LoRa_SetTxMode(void)
{
    LoRa_WriteReg(0x01, 0x83);
}

void LoRa_SetRxMode(void)
{
    LoRa_WriteReg(0x40, 0x00); // DIO0 -> RXDONE
    LoRa_WriteReg(0x01, 0x85); // RX continuous
}

/* ==== TRANSMIT ==== */
void LoRa_Transmit(uint8_t *data, uint8_t length)
{
    // Clear IRQ
    LoRa_WriteReg(0x12, 0xFF);

    // Set FIFO pointer
    LoRa_WriteReg(0x0D, 0x00);

    // Load FIFO
    for(uint8_t i = 0; i < length; i++)
        LoRa_WriteReg(0x00, data[i]);

    // Payload length
    LoRa_WriteReg(0x22, length);

    // TX mode
    LoRa_SetTxMode();

    // Timeout-safe wait
    uint32_t start = HAL_GetTick();
    while((LoRa_ReadReg(0x12) & 0x08) == 0)
    {
        if(HAL_GetTick() - start > 100)
            break;
    }

    // Clear TX done
    LoRa_WriteReg(0x12, 0x08);

    // Back to standby
    LoRa_WriteReg(0x01, 0x81);
}

/* ==== RECEIVE ==== */
uint8_t LoRa_Receive(uint8_t *data, uint8_t maxLen)
{
    uint8_t irq = LoRa_ReadReg(0x12);

    // RX done?
    if((irq & 0x40) == 0)
        return 0;

    // CRC error?
    if(irq & 0x20)
    {
        LoRa_WriteReg(0x12, 0x20);
        return 0;
    }

    uint8_t bytes = LoRa_ReadReg(0x13);
    uint8_t addr  = LoRa_ReadReg(0x10);

    LoRa_WriteReg(0x0D, addr);

    NSS_LOW();
    LoRa_SPI(0x00);

    uint8_t count = (bytes > maxLen) ? maxLen : bytes;

    for(uint8_t i = 0; i < count; i++)
        data[i] = LoRa_SPI(0x00);

    NSS_HIGH();

    // Clear IRQ
    LoRa_WriteReg(0x12, 0xFF);

    return count;  // return actual length
}
