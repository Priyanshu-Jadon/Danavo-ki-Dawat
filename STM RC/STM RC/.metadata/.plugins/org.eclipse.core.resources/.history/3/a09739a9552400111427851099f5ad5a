#include "lora.h"

static void NSS_LOW(){HAL_GPIO_WritePin(LORA_NSS_PORT,LORA_NSS_PIN,GPIO_PIN_RESET);}
static void NSS_HIGH(){HAL_GPIO_WritePin(LORA_NSS_PORT,LORA_NSS_PIN,GPIO_PIN_SET);}

uint8_t LoRa_SPI(uint8_t data)
{
 uint8_t rx;
 HAL_SPI_TransmitReceive(&hspi2,&data,&rx,1,100);
 return rx;
}

void LoRa_WriteReg(uint8_t addr,uint8_t data)
{
 NSS_LOW();
 LoRa_SPI(addr | 0x80);
 LoRa_SPI(data);
 NSS_HIGH();
}

uint8_t LoRa_ReadReg(uint8_t addr)
{
 uint8_t val;

 NSS_LOW();
 LoRa_SPI(addr & 0x7F);
 val = LoRa_SPI(0x00);
 NSS_HIGH();

 return val;
}

void LoRa_Reset()
{
 HAL_GPIO_WritePin(LORA_RESET_PORT,LORA_RESET_PIN,0);
 HAL_Delay(10);
 HAL_GPIO_WritePin(LORA_RESET_PORT,LORA_RESET_PIN,1);
 HAL_Delay(10);
}

void LoRa_Init()
{
 LoRa_Reset();

 LoRa_WriteReg(0x12,0xFF);

 LoRa_WriteReg(0x01,0x80);
 HAL_Delay(10);

 LoRa_WriteReg(0x01,0x81);

 // frequency
 LoRa_WriteReg(0x06,0x6C);
 LoRa_WriteReg(0x07,0x80);
 LoRa_WriteReg(0x08,0x00);

 // modem config
 LoRa_WriteReg(0x1D,0x72);
 LoRa_WriteReg(0x1E,0x74);
 LoRa_WriteReg(0x26,0x04);

 // LNA boost
 LoRa_WriteReg(0x0C,0x23);

 // FIFO base
 LoRa_WriteReg(0x0E,0x00);
 LoRa_WriteReg(0x0F,0x00);

 // sync word
 LoRa_WriteReg(0x39,0x34);
}

void LoRa_SetRxMode()
{
 LoRa_WriteReg(0x40,0x00);
 LoRa_WriteReg(0x01,0x85); // RX continuous
}

uint8_t LoRa_Receive(uint8_t *data,uint8_t len)
{
    uint8_t irq = LoRa_ReadReg(0x12);

    // check RX done
    if((irq & 0x40) == 0)
        return 0;

    // check CRC error
    if(irq & 0x20)
    {
        LoRa_WriteReg(0x12,0x20);
        return 0;
    }

    uint8_t bytes = LoRa_ReadReg(0x13);
    uint8_t addr  = LoRa_ReadReg(0x10);

    LoRa_WriteReg(0x0D,addr);

    NSS_LOW();
    LoRa_SPI(0x00);

    uint8_t count = bytes;
    if(count > len) count = len;

    for(int i=0;i<count;i++)
        data[i] = LoRa_SPI(0);

    NSS_HIGH();

    // clear interrupt
    LoRa_WriteReg(0x12,0xFF);

    return 1;
}
