void decrypt(uint8_t *data, uint8_t len, uint8_t idx)
{
    uint8_t i;

    switch(idx % 8)
    {
        case 0:
            for(i = 0; i < len; i++)
                data[i] ^= 0x5A;
            break;

        case 1:
            for(i = 0; i < len; i++)
                data[i] = (uint8_t)((data[i] >> 3) | (data[i] << 5));
            break;

        case 2:
            for(i = 0; i < len; i++)
                data[i] = (uint8_t)((data[i] >> 1) | (data[i] << 7));
            break;

        case 3:
            for(i = 0; i < len; i++)
                data[i] ^= 0xA7;
            break;

        case 4:
            for(i = 0; i < len; i++)
                data[i] = (uint8_t)(((data[i] & 0xF0) >> 4) | ((data[i] & 0x0F) << 4));
            break;

        case 5:
            for(i = 0; i < len; i++)
                data[i] = (uint8_t)(~data[i]);
            break;

        case 6:
            for(i = 0; i < len; i++)
                data[i] = (uint8_t)((data[i] >> 2) | (data[i] << 6));
            break;

        case 7:
            for(i = 0; i < len; i++)
                data[i] ^= 0xC3;
            break;
    }
}
/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_SPI2_Init();
  MX_USART1_UART_Init();
  /* USER CODE BEGIN 2 */

  /* USER CODE END 2 */
  printf("LoRa Receiver Start\r\n");

  /* LoRa start */
  LoRa_Init();
  printf("LoRa Initialized !!!\r\n");
  LoRa_SetRxMode();
  printf("RX Mode SET");
  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while(1)
  {
      // Check for LoRa packet
	  //printf("Entering Loop\r\n");
	  uint8_t len = LoRa_Receive((uint8_t*)&rx, sizeof(rx));

	  if (len > 0)
	  {
//	      printf("Received len: %d\r\n", len);

	      // IMPORTANT: validate packet size
	      if (len != sizeof(Packet))
	      {
	          printf("Size mismatch! Expected %d got %d\r\n", sizeof(Packet), len);
	          continue;
	      }

	      printf("RX ENC: T:%d Y:%d P:%d R:%d IDX:%d ARM:%d MODE:%d\r\n",
	             rx.THROTTLE,
	             rx.YAW,
	             rx.PITCH,
	             rx.ROLL,
	             rx.idx,
	             arm,
	             mode);
	      if (rx.header != 0xAA)
	      {
	          printf("Invalid header!\n");
	          continue;
	      }

	      decrypt((uint8_t*)&rx + 1, sizeof(rx) - 1, rx.idx);

	      arm  = (rx.CMD >> 7) & 0x01;
	      mode = (rx.CMD >> 5) & 0x03;

	      printf("RX RAW: T:%d Y:%d P:%d R:%d IDX:%d ARM:%d MODE:%d\r\n",
	             rx.THROTTLE,
	             rx.YAW,
	             rx.PITCH,
	             rx.ROLL,
	             rx.idx,
	             arm,
	             mode);

	      HAL_GPIO_WritePin(GPIOC, GPIO_PIN_13, 1);

	      //sendCRSF(&rx);

	      lastPacketTime = HAL_GetTick();

	      LoRa_SetRxMode();   // 🔥 VERY IMPORTANT
	  }
	  else
	  {
	      HAL_GPIO_WritePin(GPIOC, GPIO_PIN_13, 0);
	  }

      if (HAL_GetTick() - lastPacketTime > 500)
         {
			 rx.THROTTLE = 0;
			 rx.YAW = 2048;
			 rx.PITCH = 2048;
			 rx.ROLL = 2048;
			 arm = 0;         // Fail-safe: throttle to minimum
//             sendCRSF(&rx);            // Send CRSF frame with safe values
         }
      // Optional: small delay
      HAL_Delay(50);
  }
  /* USER CODE END 3 */
}

