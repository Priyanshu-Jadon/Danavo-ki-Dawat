#define CRSF_MIN    172
#define CRSF_CENTER 992
#define CRSF_MAX    1811

uint16_t mapToCRSF(uint16_t raw) {
    // Assuming raw is 0–4095
    uint16_t pwm = (raw * 1000) / 4095 + 1000; // scale to 1000-2000
    return CRSF_MIN + ((pwm - 1000) * (CRSF_MAX - CRSF_MIN)) / 1000;
}

// Pack 16 channels into 22-byte CRSF payload
void buildCRSFFrame(Packet *rx, uint16_t *channelsOut, uint8_t *crsfPayload) {
    // Map channels
    channelsOut[0] = mapToCRSF(rx->ROLL);
    channelsOut[1] = mapToCRSF(rx->PITCH);
    channelsOut[2] = mapToCRSF(rx->THROTTLE);
    channelsOut[3] = mapToCRSF(rx->YAW);
    channelsOut[4] = CRSF_CENTER;       // unused
    channelsOut[5] = arm ? CRSF_MAX : CRSF_MIN;          // arm/disarm placeholder
    channelsOut[6] = CRSF_MIN + ((CRSF_MAX - CRSF_MIN) / 3) * mode;
    for(int i = 7; i < 16; i++) channelsOut[i] = CRSF_CENTER;

    // Pack into 22-byte payload
    uint32_t bitBuf = 0;
    uint8_t bits = 0;
    uint8_t idx = 0;
    for(int i = 0; i < 16; i++) {
        bitBuf |= ((uint32_t)channelsOut[i] & 0x7FF) << bits; // 11-bit per channel
        bits += 11;
        while(bits >= 8) {
            crsfPayload[idx++] = bitBuf & 0xFF;
            bitBuf >>= 8;
            bits -= 8;

        }
    }

    if(bits > 0 && idx < 22) {
        crsfPayload[idx++] = bitBuf & 0xFF;
    }

}

