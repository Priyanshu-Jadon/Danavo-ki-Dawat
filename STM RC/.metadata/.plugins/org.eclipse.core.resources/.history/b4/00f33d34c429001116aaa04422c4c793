void printCRSF(uint8_t *frame, uint8_t len)
{
    printf("CRSF: ");
    for(int i = 0; i < len; i++)
    {
        printf("%02X ", frame[i]);
    }
    printf("\n");
}

// Send CRSF frame over UART
uint8_t crsf_crc8(uint8_t *data, int len)
{
    uint8_t crc = 0;

    for (int i = 0; i < len; i++) {
        crc ^= data[i];
        for (int j = 0; j < 8; j++) {
            if (crc & 0x80)
                crc = (crc << 1) ^ 0xD5;
            else
                crc <<= 1;
        }
    }
    return crc;
}

void sendCRSF(Packet *rx) {
    uint16_t channels[16];
    uint8_t crsfPayload[22] = {0};
    buildCRSFFrame(rx, channels, crsfPayload);


    // Build full frame: [ADDRESS][len][type][payload][crc]
    uint8_t crsfFrame[26];
    crsfFrame[0] = 0xC8;  // ADDERSS
    crsfFrame[1] = 24;   // LENGTH = TYPE + PAYLOAD + CRC
    crsfFrame[2] = 0x16; // RC channel type


    memcpy(&crsfFrame[3], crsfPayload, 22);

    // CRC = XOR of all bytes except length

    crsfFrame[25] = crsf_crc8(&crsfFrame[2], 23);

    // Send via UART1
    printCRSF(crsfFrame, 26);
    printf("CH: ");
    for(int i = 0; i < 8; i++)
    {
        printf("%d ", channels[i]);
    }
    printf("\n");
    //HAL_UART_Transmit(&huart1, crsfFrame, 26, 50);
}

