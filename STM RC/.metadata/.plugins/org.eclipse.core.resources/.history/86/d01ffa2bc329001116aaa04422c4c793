/* Packet structure */
typedef struct __attribute__((packed))
{
	uint8_t header;
    uint8_t idx;
    uint16_t THROTTLE;
    uint16_t YAW;
    uint16_t PITCH;
    uint16_t ROLL;
    uint8_t CMD;
} Packet;

Packet tx;
tx.header = 0xAA;

uint8_t logicIndex = 0;
/* Private user code ---------------------------------------------------------*/
/* USER CODE BEGIN 0 */
void encrypt(uint8_t *data, uint8_t len, uint8_t idx)
{
    uint8_t i;

    switch(idx % 8)
    {
        case 0:
            for(i = 0; i < len; i++)
                data[i] ^= 0x5A;
            break;

        case 1:
            for(i = 0; i < len; i++)
                data[i] = (uint8_t)((data[i] << 3) | (data[i] >> 5));
            break;

        case 2:
            for(i = 0; i < len; i++)
                data[i] = (uint8_t)((data[i] << 1) | (data[i] >> 7));
            break;

        case 3:
            for(i = 0; i < len; i++)
                data[i] ^= 0xA7;
            break;

        case 4:
            for(i = 0; i < len; i++)
                data[i] = (uint8_t)(((data[i] & 0xF0) >> 4) | ((data[i] & 0x0F) << 4));
            break;

        case 5:
            for(i = 0; i < len; i++)
                data[i] = (uint8_t)(~data[i]);
            break;

        case 6:
            for(i = 0; i < len; i++)
                data[i] = (uint8_t)((data[i] << 2) | (data[i] >> 6));
            break;

        case 7:
            for(i = 0; i < len; i++)
                data[i] ^= 0xC3;
            break;
    }
}

void printEncryptedPacket(Packet *p)
{
    uint8_t *data = (uint8_t*)p;

    uint16_t encThrottle = (data[2] << 8) | data[1];
    uint16_t encYaw      = (data[4] << 8) | data[3];
    uint16_t encPitch    = (data[6] << 8) | data[5];
    uint16_t encRoll     = (data[8] << 8) | data[7];

    printf("ENC -> Throttle: %u Yaw: %u Pitch: %u Roll: %u\r\n",
            encThrottle,
            encYaw,
            encPitch,
            encRoll);
}

// Read mode switch ADC and map to 0-3
uint8_t readModeSwitch(uint32_t adcValue)
{
    // Divide 0–4095 range into 4 equal sections
    if (adcValue < 819) return 0;
    else if (adcValue > 3276) return 2;
//    else if (adcValue < 3072) return 2;
    else return 1;
}
uint8_t buildCMDByte(uint8_t arm, uint8_t mode)
{
    // Ensure mode is 2 bits, arm is 1 bit
    mode &= 0x03;
    arm &= 0x01;

    // Place in MSB
    return (arm << 7) | (mode << 5);
    // LSBs 4-0 = 0, safe from noise
}
