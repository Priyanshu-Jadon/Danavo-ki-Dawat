/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

	HAL_Init();

	SystemClock_Config();

	MX_GPIO_Init();
	MX_ADC1_Init();
	MX_SPI2_Init();
	MX_USART1_UART_Init();

	/* Initialize LoRa */
	LoRa_Init();

	printf("SX1278 RC Transmitter Started\r\n");

	while (1)
	{
		tx.THROTTLE = Read_ADC(ADC_CHANNEL_0);
		tx.YAW      = Read_ADC(ADC_CHANNEL_1);
		tx.PITCH    = Read_ADC(ADC_CHANNEL_2);
		tx.ROLL     = Read_ADC(ADC_CHANNEL_3);
		tx.idx		= logicIndex;
		// Read mode switch from ADC
		uint16_t modeADC = Read_ADC(ADC_CHANNEL_4);
		uint8_t mode = readModeSwitch(modeADC);

		// Read ARM/Disarm button (digital input)
		uint8_t armButton = HAL_GPIO_ReadPin(GPIOB, GPIO_PIN_0); // example pin

		tx.CMD = buildCMDByte(armButton, mode);

		printf("Raw Values: Throttle: %d Yaw: %d Pitch: %d Roll: %d LogicIndex: %d ARM: %d MODE: %d\r\n",
		       tx.THROTTLE,
		       tx.YAW,
		       tx.PITCH,
		       tx.ROLL,
		       tx.idx,
		       (tx.CMD >> 7) & 0x01,      // ARM
		       (tx.CMD >> 5) & 0x03       // MODE
		);

		Packet tx_copy = tx;

		encrypt((uint8_t*)&tx_copy + 1, sizeof(tx_copy) - 1, logicIndex);

		printEncryptedPacket(&tx_copy);

		/* Send packet via LoRa */
		//uint32_t tx_time = HAL_GetTick();  // or use micros() if available
		LoRa_Transmit((uint8_t*)&tx_copy, sizeof(tx_copy));
		logicIndex++;

		/* Blink LED */
		HAL_GPIO_TogglePin(GPIOC,GPIO_PIN_13);

		HAL_Delay(50);
	}
}
